# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json
!terraform.tfvars.example

# Plan output
tfplan
*.tfplan

# Override files (usually local overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Lock file is committed by convention, do NOT ignore
# .terraform.lock.hcl

# Nix / direnv
.direnv/
.devenv/
result
result-*

# Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Generated docs
docs/reference.md

# Local env files
.env
.env.local
