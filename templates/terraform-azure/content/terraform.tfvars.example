# Copy to terraform.tfvars and edit. terraform.tfvars is gitignored.

subscription_id = "${{ values.azureSubscriptionId }}"
location        = "${{ values.azureLocation }}"
environment     = "dev"
owner           = "${{ values.owner }}"

vnet_address_space      = ["10.0.0.0/16"]
default_subnet_prefixes = ["10.0.1.0/24"]

tags = {
  cost_center = "replace-me"
  project     = "${{ values.name }}"
}
